# Snowflake Connection Credentials
# Copy this file to '.env' inside the backend folder and fill in your details,
# or enter your credentials directly in the web UI when saving to Snowflake.

SNOWFLAKE_ACCOUNT=your_account_identifier.us-east-1
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_ROLE=SYSADMIN
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=MY_DB
SNOWFLAKE_SCHEMA=PUBLIC
